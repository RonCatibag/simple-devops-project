pipeline {
    agent any

    environment {
        IMAGE_NAME     = 'portfolio'
        CONTAINER_NAME = 'portfolio'
        DEPLOY_PORT    = '4200'
        NETWORK        = 'ci-net'
    }

    stages {
        stage('Build Image') {
            steps {
                dir('my-portfolio') {
                    sh "docker build -t ${IMAGE_NAME}:${BUILD_NUMBER} -t ${IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Deploy') {
            when { branch 'main' }
            steps {
                sh """
                    docker stop ${CONTAINER_NAME} || true
                    docker rm   ${CONTAINER_NAME} || true
                    docker run -d \
                        --name ${CONTAINER_NAME} \
                        --network ${NETWORK} \
                        --restart unless-stopped \
                        -p ${DEPLOY_PORT}:80 \
                        ${IMAGE_NAME}:latest
                """
            }
        }

        stage('Smoke Test') {
            when { branch 'main' }
            steps {
                sh """
                    sleep 5
                    curl -sf http://${CONTAINER_NAME}:80/ || \
                    curl -sf http://localhost:${DEPLOY_PORT}/
                """
            }
        }

        stage('Cleanup Old Images') {
            steps {
                sh "docker image prune -f --filter 'label!=keep' || true"
            }
        }
    }

    post {
        success { echo "Portfolio deployed successfully (build #${BUILD_NUMBER})." }
        failure { echo 'Pipeline failed — check the logs above.' }
        always  { cleanWs() }
    }
}
